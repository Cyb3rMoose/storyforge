# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Whisper transcription) ────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Runway (video clip generation) ────────────────────────────────────────────
RUNWAYML_API_SECRET=...

# ── AWS (S3 + CloudFront) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-west-2
AWS_S3_BUCKET=storyforge-media

# ── API Security (OWASP API2) ─────────────────────────────────────────────────
# Set a strong random value to enable API key authentication on all endpoints.
# Leave blank to run without auth in local dev (not recommended for production).
API_KEY=

# ── CORS (OWASP API8) ─────────────────────────────────────────────────────────
# Origin allowed to call the backend. Defaults to http://localhost:5173 in dev.
CORS_ORIGIN=http://localhost:5173

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# URL of the backend API (defaults to http://localhost:3001 in dev)
VITE_API_URL=http://localhost:3001
# API key sent by the frontend as X-API-Key header — must match API_KEY above
VITE_API_KEY=
